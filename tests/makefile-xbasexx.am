# lists
XBASEXX_TESTS_LIST			= tests/xbasexx-encoding \
					  tests/xbasexx-encoded-size \
					  tests/xbasexx-encode1 \
					  tests/xbasexx-encode2 \
					  tests/xbasexx-encode3 \
					  tests/xbasexx-decoded-size \
					  tests/xbasexx-decode1 \
					  tests/xbasexx-decode2 \
					  tests/xbasexx-decode3 \
					  tests/xbasexx-decode4 \
					  tests/xbasexx-verify1 \
					  tests/xbasexx-verify2 \
					  tests/xbasexx-verify3
EXTRA_PROGRAMS				+= $(XBASEXX_TESTS_LIST)

# conditional build
if ENABLE_ADDITIONAL_TESTS
   TESTS				+= $(XBASEXX_TESTS_LIST)
   XFAIL_TESTS				+= $(XBASEXX_TESTS_LIST)
endif


# macros for tests/xbasexx-encoding
tests_xbasexx_encoding_DEPENDENCIES	= Makefile config.h $(lib_LTLIBRARIES)
tests_xbasexx_encoding_LDADD		= $(lib_LTLIBRARIES)
tests_xbasexx_encoding_CFLAGS		= $(AM_CFLAGS) -DXTEST_ENCODING=1
tests_xbasexx_encoding_SOURCES		= tests/xtest-basexx.c


